rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
  return isSignedIn() && (
    request.auth.uid == 'ZzOKXow0RlhaK3snDD0BLcbeBL62' ||
    request.auth.uid == 'obaW90LhdhPDvbvh06wWwBfucTk1'
  );
}

    /* =====================================================
       CATCH-ALL: Public reads, admin full access
       ===================================================== */
    match /{document=**} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /* =====================================================
       USERS (PUBLIC PROFILE DATA ONLY)
       ===================================================== */
    match /users/{userId} {
      allow get, list: if true;
      allow create, update, delete: if isOwner(userId) || isAdmin();
    }

    /* =====================================================
       🔐 PRIVATE USER DATA (EMAIL / MOBILE)
       ONLY USER + ADMIN
       ===================================================== */
    match /users/{userId}/private/{docId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create, update, delete: if isOwner(userId) || isAdmin();
    }

    /* =====================================================
       MINING SESSIONS
       ===================================================== */
    match /users/{userId}/miningSessions/{miningSessionId} {
      allow get, list: if true;
      allow create, update, delete:
        if (isOwner(userId) && request.resource.data.userId == userId)
        || isAdmin();
    }

    /* =====================================================
       USER PROFILE SUBCOLLECTION
       ===================================================== */
    match /users/{userId}/userProfile/{profileId} {
      allow get, list: if true;
      allow create, update, delete:
        if (isOwner(userId) && request.resource.data.userId == userId)
        || isAdmin();
    }

    /* =====================================================
       USER NOTES
       ===================================================== */
    match /users/{userId}/notes/{noteId} {
      allow get, list: if true;
      allow create, update, delete:
        if isOwner(userId) || isAdmin();
    }

    /* =====================================================
       PENDING TRANSFERS
       ===================================================== */
    match /pendingTransfers/{transferId} {
      allow get, list: if true;
      allow create: if isSignedIn() || isAdmin();
      allow update: if isAdmin();
      allow delete:
        if (isSignedIn() && request.auth.uid == resource.data.receiverId)
        || isAdmin();
    }

    /* =====================================================
       REFERRAL REQUESTS
       ===================================================== */
    match /referralRequests/{requestId} {
      allow get, list: if true;
      allow create:
        if isSignedIn()
        && request.resource.data.requesterId == request.auth.uid
        && request.resource.data.targetUserId != request.auth.uid
        && request.resource.data.status == 'pending'
        || isAdmin();

      allow update:
        if (isSignedIn()
        && request.auth.uid == resource.data.targetUserId)
        || isAdmin();

      allow delete:
        if isSignedIn()
        && (request.auth.uid == resource.data.requesterId
        || request.auth.uid == resource.data.targetUserId)
        || isAdmin();
    }

    /* =====================================================
       TRANSACTIONS (DEV MODE)
       ===================================================== */
    match /transactions/{transactionId} {
      allow get, list, create, update, delete: if true;
    }

    /* =====================================================
       WITHDRAWAL REQUESTS
       ===================================================== */
    match /withdrawalRequests/{withdrawalId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
