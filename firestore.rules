
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      let isSuperAdmin = request.auth.uid == 'ZzOKXow0RlhaK3snDD0BLcbeBL62' || request.auth.uid == 'obaW90LhdhPDvbvh06wWwBfucTk1';
      // Use exists() to prevent errors on non-existent user docs (e.g., during creation)
      let hasAdminFlag = exists(/databases/$(database)/documents/users/$(request.auth.uid))
                         && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
      return isSuperAdmin || hasAdminFlag;
    }
    
    // --- User Document Update Logic ---
    function isAllowedUserUpdate(userId) {
      let writeData = request.resource.data;
      let existingData = resource.data;
      
      // --- Protected fields that users can NEVER change themselves ---
      if (!isAdmin()) {
        if (writeData.isAdmin != existingData.isAdmin || 
            (existingData.referredBy != null && writeData.referredBy != existingData.referredBy)) {
          return false;
        }
      }
      
      // --- Scenario 2: Finalizing a session (calculating unclaimedCoins) ---
      // This MUST remain for the client to trigger session finalization.
      if (writeData.unclaimedCoins > existingData.unclaimedCoins) {
        let incrementAmount = writeData.unclaimedCoins - existingData.unclaimedCoins;
        let isEndingSession = writeData.miningStartTime == null && existingData.miningStartTime != null;
        let isReasonableIncrement = incrementAmount > 0 && incrementAmount < 1000;
        
        return isEndingSession && isReasonableIncrement;
      }
      
      // --- Scenario 3: Regular profile update or other non-financial changes. ---
      // This allows updates as long as they don't touch the main coin balances in a disallowed way.
      if (writeData.minedCoins == existingData.minedCoins && writeData.unclaimedCoins == existingData.unclaimedCoins) {
        return true;
      }
      
      // Deny any other type of update to coin balances by default
      return false;
    }

    // --- Main Rules ---
    match /users/{userId} {
      allow read, list, delete: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if isSignedIn() && isOwner(userId);
      // Replace broad update rule with granular logic
      allow update: if (isSignedIn() && isOwner(userId) && isAllowedUserUpdate(userId)) || (isSignedIn() && isAdmin());
      
      // Private subcollection rule
      match /private/{docId} {
        allow read, write: if isSignedIn() && (isOwner(userId) || isAdmin());
      }
    }
    
    // Other collections...
    match /referralRequests/{requestId} {
      allow read: if isSignedIn() && (isOwner(request.resource.data.targetUserId) || isAdmin());
      allow create: if isSignedIn() && isOwner(request.resource.data.requesterId);
      allow delete: if isSignedIn() && (isOwner(request.resource.data.targetUserId) || isAdmin());
    }

    match /transactions/{transactionId} {
      allow read, list: if isSignedIn() && (isOwner(resource.data.senderId) || isOwner(resource.data.receiverId) || isAdmin());
      allow create: if isSignedIn() && isOwner(request.resource.data.senderId);
      allow update: if isSignedIn() && isAdmin();
    }
    
    match /pendingTransfers/{transferId} {
      allow read, list: if isSignedIn() && isAdmin();
      allow create: if isSignedIn() && isOwner(request.resource.data.senderId);
      allow delete: if isSignedIn() && isAdmin();
    }

    match /reviews/{reviewId} {
      allow read, list: if isSignedIn() && isAdmin();
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update, delete: if isSignedIn() && isAdmin();
    }

    match /config/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isAdmin();
    }
    
    match /universal_messages/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isAdmin();
    }
  }
}
